# Database
DATABASE_URL=postgresql+asyncpg://acg:acg@localhost:5432/acg

# JWT Authentication
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# File Storage
FILE_STORAGE_BACKEND=local  # Options: local, minio, s3
FILE_STORAGE_PATH=./data/uploads

# MinIO (if using minio backend)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=acg-documents

# S3 (if using s3 backend)
S3_BUCKET=acg-documents
S3_REGION=us-east-1

# LLM Provider
LLM_PROVIDER=openrouter  # Options: openrouter, anthropic, openai, ollama, dummy
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# Anthropic (if using anthropic provider)
ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenAI (if using openai provider)
OPENAI_API_KEY=your-openai-api-key

# Ollama (if using ollama provider)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Google OAuth (for Drive, Gmail, Calendar integration)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/oauth/google/callback
GOOGLE_TOKEN_ENCRYPTION_KEY=generate-with-python-cryptography-fernet

# Source Monitoring
SOURCE_POLL_DEFAULT_INTERVAL_MINUTES=15
SOURCE_POLL_MAX_FILES=10

# Escalation
ESCALATION_DEFAULT_DELAY_SECONDS=86400
ESCALATION_MAX_STEPS=5

# Reports
REPORT_STORAGE_PATH=./data/reports

# WebSocket
WEBSOCKET_HEARTBEAT_SECONDS=30
WEBSOCKET_RATE_LIMIT_SECONDS=1.0
WEBSOCKET_RECONNECT_MAX_SECONDS=30

# Feature Flags
USE_DUMMY_ADAPTERS=false  # Set to true for testing without Google credentials

# CORS (for frontend)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Environment
ENVIRONMENT=development  # Options: development, staging, production
